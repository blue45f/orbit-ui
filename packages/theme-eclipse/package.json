{
  "name": "@heejun-com/theme-eclipse",
  "version": "2.0.0-beta.16",
  "type": "module",
  "description": "Orbit UI Eclipse 테마 컴포넌트",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./token": {
      "types": "./dist/token.d.ts",
      "import": "./dist/token.js",
      "require": "./dist/token.cjs"
    },
    "./base": {
      "types": "./dist/base.d.ts",
      "import": "./dist/base.js",
      "require": "./dist/base.cjs"
    },
    "./composites": {
      "types": "./dist/composites.d.ts",
      "import": "./dist/composites.js",
      "require": "./dist/composites.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "sideEffects": [
    "*.css"
  ],
  "browserslist": [
    "chrome >= 105",
    "safari >= 15",
    "ios_saf >= 15"
  ],
  "scripts": {
    "dev": "storybook dev -p 6007",
    "storybook": "storybook dev -p 6007",
    "build": "vite build && pnpm build:dts",
    "lint": "eslint src",
    "build:dts": "tsc -p tsconfig.dts.json",
    "build-storybook": "storybook build",
    "build:storybook": "storybook build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "clean": "rm -rf dist coverage storybook-static"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.7",
    "@heejun-com/core": "workspace:*",
    "@heejun-com/icons": "workspace:*",
    "@radix-ui/react-avatar": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-hover-card": "^1.1.16",
    "@radix-ui/react-progress": "^1.1.9",
    "@radix-ui/react-slider": "^1.4.0",
    "@radix-ui/react-switch": "^1.3.0",
    "@tanstack/react-table": "^8.21.3",
    "@tiptap/extension-character-count": "^3.26.0",
    "@tiptap/extension-image": "^3.26.0",
    "@tiptap/extension-link": "^3.26.0",
    "@tiptap/extension-placeholder": "^3.26.0",
    "@tiptap/pm": "^3.26.0",
    "@tiptap/react": "^3.26.0",
    "@tiptap/starter-kit": "^3.26.0",
    "@use-gesture/react": "^10.3.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "dequal": "^2.0.3",
    "embla-carousel": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "lottie-web": "^5.13.0",
    "react-day-picker": "^10.0.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/plugin-transform-runtime": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@orbit-ui/tsconfig": "workspace:*",
    "@orbit-ui/vite-plugin": "workspace:*",
    "@playwright/test": "^1.60.0",
    "@rollup/plugin-babel": "^7.1.0",
    "@storybook/addon-a11y": "^10.4.2",
    "@storybook/addon-docs": "^10.4.2",
    "@storybook/addon-links": "^10.4.2",
    "@storybook/react": "^10.4.2",
    "@storybook/react-vite": "^10.4.2",
    "@testing-library/dom": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react-swc": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "autoprefixer": "^10.5.0",
    "jsdom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "storybook": "^10.4.2",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  }
}
