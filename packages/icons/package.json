{
  "name": "@heejun-com/icons",
  "version": "2.0.0-beta.16",
  "type": "module",
  "description": "Orbit UI 아이콘 컴포넌트",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "module": "./dist/index.js",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "browserslist": [
    "chrome >= 105",
    "safari >= 15"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --outputFile='./coverage/junit.xml' --reporter=default --reporter=junit --coverage.reporter=text --coverage.reporter=text-summary --coverage.reporter=cobertura",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "build": "vite build && pnpm build:dts",
    "build:dts": "tsc -p tsconfig.dts.json",
    "version": "npm version"
  },
  "dependencies": {},
  "devDependencies": {
    "@orbit-ui/tsconfig": "workspace:^",
    "@testing-library/dom": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react-swc": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "jsdom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  }
}
