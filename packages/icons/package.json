{
  "name": "@orbit-ui/icons",
  "version": "2.0.0-beta.16",
  "type": "module",
  "description": "Orbit UI 아이콘 컴포넌트",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "module": "./dist/index.js",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "browserslist": [
    "chrome >= 105",
    "safari >= 15"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --outputFile='./coverage/junit.xml' --reporter=default --reporter=junit --coverage.reporter=text --coverage.reporter=text-summary --coverage.reporter=cobertura",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "build": "vite build && pnpm build:dts",
    "build:dts": "tsc -p tsconfig.dts.json",
    "version": "npm version"
  },
  "dependencies": {},
  "devDependencies": {
    "@orbit-ui/tsconfig": "workspace:^",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "20.11.30",
    "@types/react": "19.1.13",
    "@types/react-dom": "19.1.9",
    "@vitejs/plugin-react-swc": "3.11.0",
    "@vitest/coverage-v8": "3.2.4",
    "@vitest/ui": "3.2.4",
    "jsdom": "25.0.1",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "typescript": "5.5.4",
    "vite": "5.4.20",
    "vitest": "3.2.4"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  }
}
