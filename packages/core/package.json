{
  "name": "@heejun-com/core",
  "version": "2.0.0-beta.16",
  "type": "module",
  "description": "Orbit UI Core 컴포넌트 - 스타일 미적용 기능 컴포넌트",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./public": {
      "types": "./dist/public.d.ts",
      "import": "./dist/public.js",
      "require": "./dist/public.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "sideEffects": [
    "*.css"
  ],
  "browserslist": [
    "chrome >= 105",
    "safari >= 15"
  ],
  "scripts": {
    "preinstall": "mkdir -p dist && touch dist/style.css",
    "dev": "storybook dev -p 6009",
    "build": "vite build && pnpm build:css && pnpm build:dts",
    "lint": "eslint src",
    "build:css": "BROWSERSLIST_IGNORE_OLD_DATA=1 tailwindcss -i ./src/styles/globals.css -o ./dist/style.css --minify",
    "build:dts": "tsc -p tsconfig.dts.json",
    "build-storybook": "storybook build",
    "build:storybook": "storybook build",
    "storybook": "storybook dev -p 6009",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist coverage storybook-static"
  },
  "dependencies": {
    "@heejun-com/icons": "workspace:*",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-compose-refs": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dismissable-layer": "^1.1.11",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-portal": "^1.1.10",
    "@radix-ui/react-presence": "^1.1.5",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@tanstack/match-sorter-utils": "^8.19.4",
    "@tanstack/react-table": "^8.21.3",
    "@use-gesture/react": "^10.3.1",
    "aria-hidden": "^1.2.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.3.0",
    "embla-carousel": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "es-toolkit": "^1.47.0",
    "framer-motion": "^12.40.0",
    "lottie-web": "^5.13.0",
    "react-day-picker": "^10.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@orbit-ui/tsconfig": "workspace:*",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-links": "^10.4.1",
    "@storybook/react": "^10.4.1",
    "@storybook/react-vite": "^10.4.1",
    "@tailwindcss/cli": "^4.3.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/dom": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react-swc": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "autoprefixer": "^10.5.0",
    "jsdom": "catalog:",
    "postcss": "^8.5.15",
    "react": "catalog:",
    "react-dom": "catalog:",
    "storybook": "^10.4.1",
    "tailwindcss": "^4.3.0",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  }
}
