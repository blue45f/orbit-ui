{
  "name": "@ui-forge/vite-plugin",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "files": [
    "dist"
  ],
  "description": "UI Forge CSS Re-order Plugin for Vite",
  "license": "MIT",
  "scripts": {
    "test": "vitest run",
    "lint": "eslint src --ext ts",
